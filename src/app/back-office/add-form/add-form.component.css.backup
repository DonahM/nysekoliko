/* ===================================
   DESIGN MAGNIFIQUE - FORMULAIRE AJOUT CLASSE
   =================================== */

/* Variables de couleur */
:root {
  --primary-color: #667eea;
  --primary-dark: #5a67d8;
  --secondary-color: #764ba2;
  --accent-color: #f093fb;
  --success-color: #48bb78;
  --warning-color: #ed8936;
  --danger-color: #f56565;
  --info-color: #4299e1;
  --text-primary: #1a202c;
  --text-secondary: #4a5568;
  --text-muted: #718096;
  --bg-primary: #ffffff;
  --bg-secondary: #f7fafc;
  --bg-tertiary: #edf2f7;
  --border-color: #e2e8f0;
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12);
  --shadow-xl: 0 20px 60px rgba(0, 0, 0, 0.15);
  --gradient-primary: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  --gradient-hero: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  --gradient-success: linear-gradient(135deg, var(--success-color) 0%, #38a169 100%);
  --gradient-warning: linear-gradient(135deg, var(--warning-color) 0%, #dd6b20 100%);
}

/* ===================================
   CONTAINER PRINCIPAL
   =================================== */
.classform {
  max-width: 900px;
  margin: 0 auto;
  padding: 40px 20px;
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  position: relative;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* Background pattern */
.classform::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 20% 80%, rgba(102, 126, 234, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(118, 75, 162, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 40% 40%, rgba(240, 147, 251, 0.05) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* ===================================
   HEADER HERO
   =================================== */
.headerTableform {
  position: relative;
  background: var(--gradient-hero);
  border-radius: 24px;
  padding: 50px 40px;
  margin-bottom: 40px;
  box-shadow: var(--shadow-xl);
  overflow: hidden;
  z-index: 1;
  text-align: center;
}

.headerTableform::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  overflow: hidden;
}

.headerTableform::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: heroRotate 20s linear infinite;
}

@keyframes heroRotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.headerTableform h1 {
  position: relative;
  z-index: 2;
  margin: 0;
  font-size: 48px;
  font-weight: 900;
  color: white;
  text-shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
  letter-spacing: -1px;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16px;
  animation: titleGlow 3s ease-in-out infinite alternate;
}

.headerTableform h1::before {
  content: '🏫';
  font-size: 56px;
  animation: float 3s ease-in-out infinite;
}

@keyframes titleGlow {
  from { text-shadow: 0 4px 8px rgba(0, 0, 0, 0.3), 0 0 20px rgba(255, 255, 255, 0.2); }
  to { text-shadow: 0 4px 8px rgba(0, 0, 0, 0.3), 0 0 30px rgba(255, 255, 255, 0.4); }
}

@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-10px); }
}

/* ===================================
   SEPARATOR MODERNE */
hr {
  border: none;
  height: 2px;
  background: var(--gradient-primary);
  margin: 40px 0;
  border-radius: 2px;
  opacity: 0.3;
  position: relative;
  z-index: 1;
}

/* ===================================
   CARDS CONTAINER
   =================================== */
.cardClass {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
  gap: 30px;
  margin-bottom: 40px;
  animation: fadeInUp 0.8s ease-out;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===================================
   FORM CARDS MODERNES
   =================================== */
.cardform {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(25px);
  border-radius: 20px;
  padding: 30px;
  box-shadow: 
    0 25px 50px rgba(0, 0, 0, 0.1),
    0 0 0 1px rgba(255, 255, 255, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.4);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.cardform::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--gradient-primary);
  border-radius: 20px 20px 0 0;
}

.cardform:hover {
  transform: translateY(-5px);
  box-shadow: 
    0 30px 60px rgba(0, 0, 0, 0.15),
    0 0 0 1px rgba(255, 255, 255, 0.4),
    inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

.cardform h3 {
  margin: 0 0 20px 0;
  font-size: 18px;
  font-weight: 800;
  color: var(--text-primary);
  text-transform: uppercase;
  letter-spacing: 1px;
  display: flex;
  align-items: center;
  gap: 10px;
  position: relative;
  padding-left: 35px;
}

.cardform h3::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 24px;
  height: 24px;
  background: var(--gradient-primary);
  border-radius: 50%;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
}

.cardform:nth-child(1) h3::before { content: '📝'; }
.cardform:nth-child(2) h3::before { content: '👨‍🏫'; }
.cardform:nth-child(3) h3::before { content: '🔢'; }
.cardform:nth-child(4) h3::before { content: '📅'; }

/* ===================================
   MAT FORM FIELD STYLING
   =================================== */
.mat-mdc-form-field {
  width: 100%;
  margin-bottom: 8px;
}

.mat-mdc-form-field-flex {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12px;
  border: 2px solid var(--border-color);
  transition: all 0.3s ease;
  backdrop-filter: blur(10px);
}

.mat-mdc-form-field-flex:hover {
  border-color: #a5b4fc;
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.1);
}

.mat-mdc-form-field-focus .mat-mdc-form-field-flex {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.15);
  background: white;
}

.mat-mdc-text-field-wrapper {
  padding: 0;
}

.mat-mdc-form-field-infix {
  padding: 16px 16px 8px 16px;
  min-height: 56px;
}

.mat-mdc-form-field-label {
  color: var(--text-muted);
  font-weight: 600;
  font-size: 14px;
  top: 18px;
}

.mat-mdc-form-field-focus .mat-mdc-form-field-label {
  color: var(--primary-color);
  font-weight: 700;
}

.mat-mdc-form-field-input {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.mat-mdc-select-value {
  font-size: 16px;
  font-weight: 500;
  color: var(--text-primary);
}

.mat-mdc-select-arrow {
  color: var(--primary-color);
}

/* ===================================
   SELECT OPTIONS STYLING
   =================================== */
.mat-mdc-option {
  font-weight: 500;
  color: var(--text-secondary);
  transition: all 0.2s ease;
}

.mat-mdc-option:hover {
  background: rgba(102, 126, 234, 0.1);
  color: var(--primary-color);
}

.mat-mdc-option.mdc-list-item--selected {
  background: var(--gradient-primary);
  color: white;
  font-weight: 600;
}

/* ===================================
   BUTTON SECTION
   =================================== */
.classbtn {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 50px 0;
  padding: 0 20px;
}

.classbtn button {
  background: var(--gradient-success);
  color: white;
  border: none;
  border-radius: 16px;
  padding: 18px 48px;
  font-size: 18px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  text-transform: uppercase;
  letter-spacing: 1px;
  box-shadow: 
    0 8px 25px rgba(72, 187, 120, 0.4),
    0 0 0 1px rgba(255, 255, 255, 0.2);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 12px;
}

.classbtn button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  transition: left 0.6s ease;
}

.classbtn button:hover::before {
  left: 100%;
}

.classbtn button:hover {
  background: var(--gradient-primary);
  transform: translateY(-3px) scale(1.02);
  box-shadow: 
    0 12px 35px rgba(102, 126, 234, 0.5),
    0 0 0 1px rgba(255, 255, 255, 0.3);
}

.classbtn button:active {
  transform: translateY(-1px) scale(1.01);
  box-shadow: 
    0 6px 20px rgba(102, 126, 234, 0.4),
    0 0 0 1px rgba(255, 255, 255, 0.2);
}

.classbtn button::after {
  content: '💾';
  font-size: 20px;
}

/* ===================================
   RESPONSIVE DESIGN
   =================================== */
@media (max-width: 1024px) {
  .classform {
    padding: 30px 16px;
  }
  
  .headerTableform {
    padding: 40px 30px;
  }
  
  .headerTableform h1 {
    font-size: 40px;
  }
  
  .cardClass {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 25px;
  }
}

@media (max-width: 768px) {
  .classform {
    padding: 20px 12px;
    min-height: auto;
  }
  
  .headerTableform {
    padding: 30px 20px;
    margin-bottom: 30px;
  }
  
  .headerTableform h1 {
    font-size: 32px;
  }
  
  .cardClass {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  
  .cardform {
    padding: 25px;
  }
  
  .classbtn button {
    padding: 16px 36px;
    font-size: 16px;
  }
}

@media (max-width: 480px) {
  .headerTableform {
    padding: 25px 16px;
  }
  
  .headerTableform h1 {
    font-size: 28px;
    flex-direction: column;
    gap: 12px;
  }
  
  .headerTableform h1::before {
    font-size: 40px;
  }
  
  .cardform {
    padding: 20px;
  }
  
  .cardform h3 {
    font-size: 16px;
    padding-left: 30px;
  }
  
  .classbtn {
    margin: 30px 0;
  }
  
  .classbtn button {
    padding: 14px 28px;
    font-size: 15px;
    width: 100%;
    justify-content: center;
  }
}